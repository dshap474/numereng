# Runtime store (always local, never committed)
.numereng/*
.local/
.cache/


# Data directories (downloaded and generated files)
output/
experiments/
notebooks/
predictions/
src/numereng/features/models/custom_models/
!src/numereng/features/models/custom_models/.gitkeep
!src/numereng/features/models/custom_models/template_model.py
numerai-example/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
.mypy_cache/
dist/
build/
.tmp/
.venv-test/
.import_linter_cache

# Testing
.pytest_cache/
.ruff_cache/
.import_linter_cache/
.coverage
htmlcov/
.pre-commit-cache/
.playwright-cli

# OS / generated logs
.DS_Store
*.log

# IDE
.idea/
.vscode/
*.swp

# Env files
.env
.env.*
!.env.example

# Vendored reference repos
vendor/

# Models and predictions (large files)
models/*.pkl
predictions/*.csv
/tabpfn-*.ckpt

# Viz build artifacts (for standalone repo use)
viz/web/node_modules/
viz/web/.svelte-kit/
viz/web/.vite/
viz/web/package-lock.json

# Synced docs metadata
docs/numerai/.sync-meta.json

# Scraped forum cache (local-only generated content)
docs/numerai/forum/

# Local viz runtime files
viz/*.pid

# Public export output
dist-public/

# Developer-only directories
deterministic-evaluation/
dev/
!dev/hygiene/
!dev/hygiene/*.json
.codex/rules/

# Tracked README banner asset
!docs/assets/numereng-banner.png

# Keep numereng OSS issue templates tracked (root ignore has *.github/)
!.github/
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/*.md
.omx/

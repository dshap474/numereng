{
  "$defs": {
    "HpoNeutralizationConfig": {
      "additionalProperties": false,
      "description": "Prediction-stage neutralization controls for HPO trials.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "mode": {
          "default": "era",
          "enum": [
            "era",
            "global"
          ],
          "title": "Mode",
          "type": "string"
        },
        "neutralizer_cols": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Neutralizer Cols"
        },
        "neutralizer_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Neutralizer Path"
        },
        "proportion": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Proportion",
          "type": "number"
        },
        "rank_output": {
          "default": true,
          "title": "Rank Output",
          "type": "boolean"
        }
      },
      "title": "HpoNeutralizationConfig",
      "type": "object"
    },
    "HpoObjectiveConfig": {
      "additionalProperties": false,
      "description": "Objective block for one HPO study.",
      "properties": {
        "direction": {
          "default": "maximize",
          "enum": [
            "maximize",
            "minimize"
          ],
          "title": "Direction",
          "type": "string"
        },
        "metric": {
          "default": "bmc_last_200_eras.mean",
          "title": "Metric",
          "type": "string"
        },
        "neutralization": {
          "$ref": "#/$defs/HpoNeutralizationConfig"
        }
      },
      "title": "HpoObjectiveConfig",
      "type": "object"
    },
    "HpoPlateauConfig": {
      "additionalProperties": false,
      "description": "Study-level plateau stopping controls.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "min_completed_trials": {
          "default": 15,
          "minimum": 1,
          "title": "Min Completed Trials",
          "type": "integer"
        },
        "min_improvement_abs": {
          "default": 0.00025,
          "minimum": 0.0,
          "title": "Min Improvement Abs",
          "type": "number"
        },
        "patience_completed_trials": {
          "default": 10,
          "minimum": 1,
          "title": "Patience Completed Trials",
          "type": "integer"
        }
      },
      "title": "HpoPlateauConfig",
      "type": "object"
    },
    "HpoSamplerConfig": {
      "additionalProperties": false,
      "description": "Sampler block for one HPO study.",
      "properties": {
        "group": {
          "default": false,
          "title": "Group",
          "type": "boolean"
        },
        "kind": {
          "default": "tpe",
          "enum": [
            "tpe",
            "random"
          ],
          "title": "Kind",
          "type": "string"
        },
        "multivariate": {
          "default": true,
          "title": "Multivariate",
          "type": "boolean"
        },
        "n_startup_trials": {
          "default": 10,
          "minimum": 1,
          "title": "N Startup Trials",
          "type": "integer"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 1337,
          "title": "Seed"
        }
      },
      "title": "HpoSamplerConfig",
      "type": "object"
    },
    "HpoSearchSpaceSpec": {
      "additionalProperties": false,
      "description": "Typed spec for one search-space parameter path.",
      "properties": {
        "choices": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  },
                  {
                    "type": "number"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Choices"
        },
        "high": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "High"
        },
        "log": {
          "default": false,
          "title": "Log",
          "type": "boolean"
        },
        "low": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Low"
        },
        "step": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step"
        },
        "type": {
          "enum": [
            "float",
            "int",
            "categorical"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "HpoSearchSpaceSpec",
      "type": "object"
    },
    "HpoStoppingConfig": {
      "additionalProperties": false,
      "description": "Study-level stop controls.",
      "properties": {
        "max_completed_trials": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Completed Trials"
        },
        "max_trials": {
          "default": 100,
          "minimum": 1,
          "title": "Max Trials",
          "type": "integer"
        },
        "plateau": {
          "$ref": "#/$defs/HpoPlateauConfig"
        },
        "timeout_seconds": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeout Seconds"
        }
      },
      "title": "HpoStoppingConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Canonical v2 HPO study config contract.",
  "properties": {
    "config_path": {
      "title": "Config Path",
      "type": "string"
    },
    "experiment_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Experiment Id"
    },
    "objective": {
      "$ref": "#/$defs/HpoObjectiveConfig"
    },
    "sampler": {
      "$ref": "#/$defs/HpoSamplerConfig"
    },
    "search_space": {
      "additionalProperties": {
        "$ref": "#/$defs/HpoSearchSpaceSpec"
      },
      "title": "Search Space",
      "type": "object"
    },
    "stopping": {
      "$ref": "#/$defs/HpoStoppingConfig"
    },
    "study_id": {
      "title": "Study Id",
      "type": "string"
    },
    "study_name": {
      "title": "Study Name",
      "type": "string"
    }
  },
  "required": [
    "study_id",
    "study_name",
    "config_path",
    "objective",
    "search_space",
    "sampler",
    "stopping"
  ],
  "title": "HpoStudyConfig",
  "type": "object"
}

{
  "type": "object",
  "properties": {
    "experiment_question": {
      "type": "string"
    },
    "winner_criteria": {
      "type": "string"
    },
    "decision_rationale": {
      "type": "string"
    },
    "next_action": {
      "type": "string",
      "enum": ["continue", "scale", "pivot", "stop"]
    },
    "path_hypothesis": {
      "type": "string"
    },
    "path_slug": {
      "type": "string"
    },
    "phase_action": {
      "type": "string",
      "enum": ["stay", "advance", "complete"]
    },
    "phase_transition_rationale": {
      "type": "string"
    },
    "configs": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "overrides": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "value_json": {
                  "type": "string"
                }
              },
              "required": ["path", "value_json"],
              "additionalProperties": false
            }
          }
        },
        "required": ["filename", "rationale", "overrides"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "experiment_question",
    "winner_criteria",
    "decision_rationale",
    "next_action",
    "path_hypothesis",
    "path_slug",
    "phase_action",
    "phase_transition_rationale",
    "configs"
  ],
  "additionalProperties": false
}

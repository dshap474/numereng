# Copy to .env and replace placeholders with your own credentials.

# Numerai API credentials
NUMERAI_PUBLIC_ID=your_public_id
NUMERAI_SECRET_KEY=your_secret_key

# Numerai MCP auth (Token PUBLIC_KEY$PRIVATE_KEY)
NUMERAI_MCP_AUTH=Token PUBLIC_KEY$PRIVATE_KEY

# AWS auth for boto3 / AWS CLI. Use one of:
# - shared credentials or `aws configure`
# - `AWS_PROFILE`
# - direct env vars like `AWS_ACCESS_KEY_ID` / `AWS_SECRET_ACCESS_KEY`
# AWS_PROFILE=your_aws_profile
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=your_aws_session_token

# numereng AWS defaults for `cloud aws` and `cloud ec2`
NUMERENG_AWS_REGION=us-east-2
# NUMERENG_S3_BUCKET=your_bucket_name

# Account-specific cloud defaults are intentionally unset in the public repo.
# Set the ones you need locally or pass flags explicitly.
# NUMERENG_EC2_IAM_ROLE=your_training_role
# NUMERENG_EC2_SECURITY_GROUP=your_security_group_name
# NUMERENG_EC2_AMI_CPU=ami-xxxxxxxxxxxxxxxxx
# NUMERENG_EC2_AMI_GPU=ami-yyyyyyyyyyyyyyyyy
# NUMERENG_AWS_ECR_REPOSITORY=numereng-training
# NUMERENG_AWS_SAGEMAKER_ROLE_ARN=arn:aws:iam::<account-id>:role/your-sagemaker-role
# NUMERENG_AWS_BATCH_JOB_QUEUE=your_batch_job_queue
# NUMERENG_AWS_BATCH_JOB_DEFINITION=your_batch_job_definition
# NUMERENG_AWS_SAGEMAKER_INSTANCE_TYPE=ml.m5.2xlarge

# Optional MCP / Modal credentials for local tooling
MCP_NAME=your_mcp_name
MCP_API_TOKEN=your_mcp_api_token
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

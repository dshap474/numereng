# Copy to .env and replace placeholders with your own credentials.

# Numerai API credentials
NUMERAI_PUBLIC_ID=your_public_id
NUMERAI_SECRET_KEY=your_secret_key

# Numerai MCP auth (Token PUBLIC_KEY$PRIVATE_KEY)
NUMERAI_MCP_AUTH=Token PUBLIC_KEY$PRIVATE_KEY

# Optional MCP / Modal credentials for local tooling
MCP_NAME=your_mcp_name
MCP_API_TOKEN=your_mcp_api_token
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret
